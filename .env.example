# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-32-byte-random-base64

# Database
DATABASE_URL=postgresql://app_user:change_me@localhost:5432/personal_website
DIRECT_URL=postgresql://migration_user:change_me@localhost:5432/personal_website
MIGRATION_DATABASE_URL=postgresql://migration_user:change_me@localhost:5432/personal_website
POSTGRES_DB=personal_website
POSTGRES_APP_USER=app_user
POSTGRES_APP_PASSWORD=change_me
POSTGRES_MIGRATION_USER=migration_user
POSTGRES_MIGRATION_PASSWORD=change_me
ALLOW_SEED=false
ALLOW_PROD_SEED=false
SEED_ADMIN_EMAIL=owner@staging.local
SEED_ADMIN_NAME=Platform Owner
SEED_ADMIN_PASSWORD=replace-with-strong-seed-password

# Redis / rate limiting
UPSTASH_REDIS_REST_URL=https://example.upstash.io
UPSTASH_REDIS_REST_TOKEN=change_me

# Cloudflare R2
R2_ACCOUNT_ID=change_me
R2_ACCESS_KEY_ID=change_me
R2_SECRET_ACCESS_KEY=change_me
R2_BUCKET=change_me
R2_PUBLIC_BASE_URL=https://assets.example.com

# Security
TURNSTILE_SECRET_KEY=change_me
NEXT_PUBLIC_TURNSTILE_SITE_KEY=change_me

# Email and observability
RESEND_API_KEY=change_me
SENTRY_DSN=change_me
PLAUSIBLE_DOMAIN=localhost
PLAUSIBLE_API_HOST=https://plausible.example.com
CLARITY_PROJECT_ID=change_me
